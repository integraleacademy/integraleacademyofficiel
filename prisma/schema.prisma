generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TrainingSessionStatus {
  OPEN
  FULL
  COMING_SOON
  HIDDEN
}

model Training {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String
  title       String
  category    String
  description String            @default("")
  pageUrl     String
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  sessions    TrainingSession[]
}

model TrainingSession {
  id              String                @id @default(cuid())
  trainingId      String
  training        Training              @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  title           String
  startDate       DateTime
  endDate         DateTime
  examDate        DateTime?
  priceCents      Int?
  priceLabel      String?
  location        String?
  status          TrainingSessionStatus @default(OPEN)
  seatsTotal      Int?
  seatsLeft       Int?
  showSeatsLeft   Boolean               @default(true)
  durationLabel   String?
  registrationUrl String?
  fundingNotes    String?
  publicNotes     String?
  internalNotes   String?
  sortOrder       Int                   @default(0)
  isHighlighted   Boolean               @default(false)

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

model ChatLead {
  id               String   @id @default(cuid())
  firstName        String?
  lastName         String?
  email            String?
  phone            String?
  trainingInterest String?
  message          String?
  source           String?  @default("chat")
  createdAt        DateTime @default(now())
}

model ChatConversationLog {
  id                     String   @id @default(cuid())
  userMessage            String
  assistantAnswer        String
  selectedKnowledgeFiles String?
  selectedSessions       String?
  createdAt              DateTime @default(now())
}
